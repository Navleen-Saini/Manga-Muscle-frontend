
doctype html
html(lang="en")
  head
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title #{title} | Workout Insight
    link(rel="stylesheet" href="/style.css")
    script(src="https://cdn.tailwindcss.com")
    style.
      body { font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial; }
  body(class="bg-gray-900 text-gray-100 min-h-screen")
    header(class="bg-gray-800 border-b border-gray-700 p-4")
      .container.mx-auto.flex.items-center.justify-between
        a(href="/" class="text-xl font-bold") Workout Insight
        nav
          a(href="/" class="mx-2 hover:text-green-400") Home
          a(href="/registration-form" class="mx-2 hover:text-green-400") Register
          a(href="/registration-plans" class="mx-2 hover:text-green-400") Plans
          a(href="/contacts" class="mx-2 font-semibold text-green-300") Contacts
    main.container.mx-auto.p-6
      block content
    footer.text-center.p-4.text-sm.text-gray-400
      | © #{new Date().getFullYear()} Workout Insight